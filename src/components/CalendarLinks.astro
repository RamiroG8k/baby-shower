---
import event from '../data/event.json';

// Build calendar URLs from event data
const title = encodeURIComponent(`${event.parentName}'s ${event.eventType}`);
const location = encodeURIComponent(`${event.venue}, ${event.address}`);
const description = encodeURIComponent(`${event.tagline} Hosted by ${event.hostName}.`);

// Parse times for calendar format (YYYYMMDDTHHMMSS)
const dateStr = event.date.replace(/-/g, '');
// Convert "2:00 PM" → 24h
function to24h(time: string): string {
  const [timePart, period] = time.split(' ');
  let [h, m] = timePart.split(':').map(Number);
  if (period === 'PM' && h !== 12) h += 12;
  if (period === 'AM' && h === 12) h = 0;
  return `${String(h).padStart(2, '0')}${String(m).padStart(2, '0')}00`;
}

const startCal = `${dateStr}T${to24h(event.startTime)}`;
const endCal = `${dateStr}T${to24h(event.endTime)}`;

const googleUrl = `https://calendar.google.com/calendar/render?action=TEMPLATE&text=${title}&dates=${startCal}/${endCal}&location=${location}&details=${description}`;

// ICS content for Apple/Outlook
const icsContent = `BEGIN:VCALENDAR
VERSION:2.0
BEGIN:VEVENT
DTSTART:${startCal}
DTEND:${endCal}
SUMMARY:${event.parentName}'s ${event.eventType}
LOCATION:${event.venue}, ${event.address}
DESCRIPTION:${event.tagline} Hosted by ${event.hostName}.
END:VEVENT
END:VCALENDAR`;

const icsDataUri = `data:text/calendar;charset=utf-8,${encodeURIComponent(icsContent)}`;
---

<section class="calendar section animate-on-scroll" id="calendar">
  <p class="calendar__label text-label">Save the Date</p>

  <div class="calendar__links">
    <a
      href={googleUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="pill-button pill-button--secondary calendar__btn"
    >
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
        <rect x="2" y="3" width="12" height="11" rx="2" stroke="currentColor" stroke-width="1.2" fill="none"/>
        <path d="M2 7h12M5 1v4M11 1v4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
      </svg>
      Google
    </a>

    <a
      href={icsDataUri}
      download={`${event.parentName}-baby-shower.ics`}
      class="pill-button pill-button--secondary calendar__btn"
    >
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
        <path d="M12 2H14C14.55 2 15 2.45 15 3V14C15 14.55 14.55 15 14 15H2C1.45 15 1 14.55 1 14V3C1 2.45 1.45 2 2 2H4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
        <path d="M5 1V4M11 1V4M1 7H15" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
      </svg>
      Apple
    </a>

    <a
      href={icsDataUri}
      download={`${event.parentName}-baby-shower.ics`}
      class="pill-button pill-button--secondary calendar__btn"
    >
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
        <rect x="2" y="3" width="12" height="11" rx="1" stroke="currentColor" stroke-width="1.2" fill="none"/>
        <path d="M2 7h12M5 1v4M11 1v4M6 10h4M6 12h2" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
      </svg>
      Outlook
    </a>
  </div>
</section>

<style>
  .calendar {
    text-align: center;
    padding-top: var(--space-lg);
    padding-bottom: var(--space-lg);
  }

  .calendar__label {
    color: var(--outline);
    margin-bottom: var(--space-md);
  }

  .calendar__links {
    display: flex;
    justify-content: center;
    gap: var(--space-sm);
    flex-wrap: wrap;
  }

  .calendar__btn {
    font-size: 13px;
    padding: var(--space-sm) var(--space-lg);
    min-height: 40px;
  }
</style>

---
import event from '../data/event.json';
import Botanical from './svg/Botanical.astro';

const waLink = `https://wa.me/${event.whatsapp.replace(/[^0-9]/g, '')}?text=${encodeURIComponent(`¡Hola! Sobre el Baby Shower de ${event.parentName}...`)}`;
---

<section class="contact section animate-on-scroll" id="contact">
  <div class="contact__botanical">
    <Botanical flip />
  </div>

  <p class="contact__message font-display">
    {event.closingMessage}
  </p>

  <p class="contact__host text-body-md">
    Con cariño, <strong>{event.hostName}</strong>
  </p>

  <div class="contact__channels">
    <a
      href={waLink}
      target="_blank"
      rel="noopener noreferrer"
      class="pill-button pill-button--primary contact__btn"
    >
      <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
        <path d="M15.05 2.91A8.46 8.46 0 009.02.48 8.49 8.49 0 001.51 12.7L.47 16.53l3.92-1.03a8.47 8.47 0 004.06 1.03h.01a8.49 8.49 0 008.49-8.49 8.44 8.44 0 00-1.9-5.13zM9.02 15.56a7.04 7.04 0 01-3.59-.98l-.26-.15-2.65.7.71-2.58-.17-.27a7.03 7.03 0 1110.99-5.76 7.04 7.04 0 01-5.03 9.04zm3.86-5.27c-.21-.1-1.25-.62-1.44-.69-.19-.07-.33-.1-.47.11-.14.21-.55.69-.67.83-.12.14-.25.16-.46.05-.21-.1-.9-.33-1.71-1.06-.63-.56-1.06-1.26-1.18-1.47-.12-.21-.01-.32.09-.43.1-.1.22-.25.32-.38.1-.12.14-.21.21-.35.07-.14.04-.26-.02-.37-.05-.1-.47-1.13-.64-1.55-.17-.41-.34-.35-.47-.36h-.4c-.14 0-.36.05-.55.26s-.72.7-.72 1.72.74 2 .84 2.13c.1.14 1.45 2.22 3.52 3.11.49.21.88.34 1.18.43.5.16.95.14 1.31.08.4-.06 1.23-.5 1.4-1 .18-.49.18-.9.12-.99-.05-.09-.19-.14-.4-.24z" fill="currentColor"/>
      </svg>
      Contáctanos por WhatsApp
    </a>

    <a
      href={`tel:${event.whatsapp.replace(/[^0-9+]/g, '')}`}
      class="pill-button pill-button--outline contact__btn"
    >
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
        <path d="M14.5 11.35v1.93a1.29 1.29 0 01-1.4 1.29 12.72 12.72 0 01-5.55-1.97 12.53 12.53 0 01-3.86-3.86A12.72 12.72 0 011.72 2.9 1.29 1.29 0 013 1.5h1.93a1.29 1.29 0 011.29 1.11c.08.61.23 1.21.44 1.79a1.29 1.29 0 01-.29 1.36l-.82.82a10.32 10.32 0 003.86 3.86l.82-.82a1.29 1.29 0 011.36-.29c.58.21 1.18.36 1.79.44a1.29 1.29 0 011.11 1.31v.07z" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
      </svg>
      {event.phone}
    </a>
  </div>
</section>

<style>
  .contact {
    text-align: center;
    padding-bottom: var(--space-4xl);
  }

  .contact__botanical {
    margin-bottom: var(--space-xl);
  }

  .contact__message {
    font-size: clamp(1.25rem, 4vw, 1.5rem);
    font-weight: 300;
    font-style: italic;
    color: var(--on-surface);
    margin-bottom: var(--space-sm);
    line-height: 1.4;
  }

  .contact__host {
    color: var(--on-surface-variant);
    margin-bottom: var(--space-xl);
  }

  .contact__channels {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    align-items: center;
  }

  .contact__btn {
    width: 100%;
    max-width: 280px;
  }
</style>

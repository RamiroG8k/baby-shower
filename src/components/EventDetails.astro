---
import event from "../data/event.json";
import Botanical from "./svg/Botanical.astro";

const dateObj = new Date(event.date);
const monthName = dateObj.toLocaleDateString("es-MX", { month: "long" });
const dayNumber = dateObj.getUTCDate();
const year = dateObj.getUTCFullYear();
---

<section class="details section" id="details">
  <div class="details__botanical animate-on-scroll">
    <Botanical />
  </div>

  <div class="details__grid animate-on-scroll delay-1">
    <div class="details__block">
      <span class="details__label text-label">{event.dayOfWeek}</span>
      <span class="details__day">{dayNumber}</span>
      <span class="details__sub">{monthName} {year}</span>
    </div>

    <div class="details__vdivider" aria-hidden="true"></div>

    <div class="details__block">
      <span class="details__label text-label">Hora</span>
      <span class="details__time">{event.startTime}</span>
      {event.endTime && <span class="details__sub">a {event.endTime}</span>}
    </div>
  </div>

  <div class="details__location animate-on-scroll delay-2">
    <div class="details__location-icon">
      <svg
        width="18"
        height="22"
        viewBox="0 0 18 22"
        fill="none"
        aria-hidden="true"
      >
        <path
          d="M9 0C4.03 0 0 4.03 0 9C0 15.75 9 22 9 22C9 22 18 15.75 18 9C18 4.03 13.97 0 9 0ZM9 12.5C7.07 12.5 5.5 10.93 5.5 9C5.5 7.07 7.07 5.5 9 5.5C10.93 5.5 12.5 7.07 12.5 9C12.5 10.93 10.93 12.5 9 12.5Z"
          fill="var(--primary)"
          opacity="0.7"></path>
      </svg>
    </div>
    <p class="details__venue">{event.venue}</p>
    <p class="details__address">{event.address}</p>

    <div style="width: 100%">
      <iframe
        width="100%"
        height="500"
        frameborder="0"
        scrolling="no"
        marginheight="0"
        marginwidth="0"
        src="https://maps.google.com/maps?width=100%25&height=500&hl=en&q=Priv.%20Pino%20Suarez%2056,%20Zapopan,%2045100%20Zapopan,%20Jal.+(Baby%20Shower)&t=&z=15&ie=UTF8&iwloc=B&output=embed"
      ></iframe>
    </div>

    <a
      href={event.mapUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="pill-button pill-button--secondary details__map-link"
    >
      <svg
        width="14"
        height="14"
        viewBox="0 0 14 14"
        fill="none"
        aria-hidden="true"
      >
        <path
          d="M5.5 1L1 3.5V13L5.5 10.5M5.5 1L9.5 3.5M5.5 1V10.5M9.5 3.5L13 1V10.5L9.5 13M9.5 3.5V13M5.5 10.5L9.5 13"
          stroke="currentColor"
          stroke-width="1.2"
          stroke-linejoin="round"></path>
      </svg>
      Ver en el Mapa
    </a>
  </div>
</section>

<style>
  .details {
    text-align: center;
    padding-top: var(--space-lg);
  }

  .details__botanical {
    margin-bottom: var(--space-xl);
  }

  .details__grid {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-xl);
    margin-bottom: var(--space-2xl);
  }

  .details__block {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-xs);
  }

  .details__label {
    color: var(--outline);
  }

  .details__day {
    font-family: var(--font-display);
    font-size: clamp(3rem, 10vw, 4.5rem);
    font-weight: 400;
    line-height: 1;
    color: var(--on-surface);
  }

  .details__time {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 5vw, 2rem);
    font-weight: 400;
    line-height: 1;
    color: var(--on-surface);
  }

  .details__sub {
    font-size: 13px;
    color: var(--on-surface-variant);
  }

  .details__vdivider {
    width: 1.5px;
    height: 60px;
    background: var(--outline-variant);
    border-radius: var(--radius-full);
  }

  .details__location {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-sm);
  }

  .details__location-icon {
    margin-bottom: var(--space-xs);
  }

  .details__venue {
    font-family: var(--font-display);
    font-size: clamp(1.2rem, 4vw, 1.5rem);
    font-weight: 500;
    color: var(--on-surface);
  }

  .details__address {
    font-size: 14px;
    color: var(--on-surface-variant);
    margin-bottom: var(--space-sm);
  }

  .details__map-link {
    font-size: 13px;
    padding: var(--space-sm) var(--space-lg);
    min-height: 40px;
    margin-top: var(--space-xs);
  }
</style>

---
interface Props {
  flip?: boolean;
}
const { flip = false } = Astro.props;
---

<svg
  class:list={['botanical', { 'botanical--flip': flip }]}
  viewBox="0 0 120 40"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
>
  <path
    d="M10 28 Q30 26 60 20 Q90 14 110 16"
    stroke="var(--primary-container)"
    stroke-width="1.5"
    stroke-linecap="round"
    fill="none"
  />
  <ellipse cx="30" cy="22" rx="8" ry="4" fill="var(--primary-container)" opacity="0.5" transform="rotate(-20 30 22)" />
  <ellipse cx="45" cy="18" rx="7" ry="3.5" fill="var(--primary-container)" opacity="0.45" transform="rotate(15 45 18)" />
  <ellipse cx="60" cy="16" rx="8" ry="4" fill="var(--primary-container)" opacity="0.4" transform="rotate(-10 60 16)" />
  <ellipse cx="75" cy="14" rx="7" ry="3.5" fill="var(--primary-container)" opacity="0.35" transform="rotate(12 75 14)" />
  <ellipse cx="90" cy="14" rx="6" ry="3" fill="var(--primary-container)" opacity="0.3" transform="rotate(-8 90 14)" />


  <ellipse cx="38" cy="26" rx="7" ry="3.5" fill="var(--primary-container)" opacity="0.4" transform="rotate(25 38 26)" />
  <ellipse cx="55" cy="22" rx="6.5" ry="3" fill="var(--primary-container)" opacity="0.35" transform="rotate(-18 55 22)" />
  <ellipse cx="72" cy="18" rx="6" ry="3" fill="var(--primary-container)" opacity="0.3" transform="rotate(20 72 18)" />
  <ellipse cx="100" cy="16" rx="5.5" ry="2.5" fill="var(--primary-container)" opacity="0.25" transform="rotate(-5 100 16)" />
</svg>

<style>
  .botanical {
    width: 100px;
    height: auto;
    margin: 0 auto;
    opacity: 0.7;
  }

  .botanical--flip {
    transform: scaleX(-1);
  }
</style>

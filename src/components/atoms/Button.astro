---
interface Props {
  variant?: "primary" | "secondary" | "tertiary" | "outline";
  type?: "button" | "submit" | "reset";
  class?: string;
  id?: string;
  [key: string]: any;
}

const {
  variant = "primary",
  type = "button",
  class: className,
  id,
  ...rest
} = Astro.props;
---

<button
  type={type}
  id={id}
  class:list={["pill-button", `pill-button--${variant}`, className]}
  {...rest}
>
  <slot />
</button>

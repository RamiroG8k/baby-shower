---
interface Props {
    as?: string;
    variant?: "label" | "body-md" | "body-lg";
    weight?: "regular" | "medium" | "light";
    italic?: boolean;
    bold?: boolean;
    class?: string;
    style?: string;
}

const {
    as: Tag = "p",
    variant = "body-md",
    weight = "regular",
    italic = false,
    bold = false,
    class: className,
    style,
} = Astro.props;

const weightMap = {
    regular: 400,
    medium: 500,
    light: 300,
};
---

<Tag
    class:list={["text", `text-${variant}`, className]}
    data-variant={variant}
    data-italic={italic}
    data-bold={bold}
    data-weight={weight}
    style={style}
>
    <slot />
</Tag>

<style>
    .text {
        font-family: var(--font-body);
        color: var(--on-surface);
        font-style: normal;
    }

    .text[data-variant="label"] {
        font-size: var(--text-label);
        font-weight: 600;
        line-height: 1;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--on-surface-variant);
    }

    .text[data-variant="body-md"] {
        font-size: var(--text-body-md);
        line-height: 1.5;
    }

    .text[data-variant="body-lg"] {
        font-size: var(--text-body-lg);
        line-height: 1.6;
    }

    .text[data-italic="true"] {
        font-style: italic;
    }

    .text[data-bold="true"] {
        font-weight: 600;
    }

    .text[data-weight="regular"] {
        font-weight: 400;
    }

    .text[data-weight="medium"] {
        font-weight: 500;
    }

    .text[data-weight="light"] {
        font-weight: 300;
    }
</style>
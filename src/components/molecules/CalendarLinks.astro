---
import event from "@data/event.json";
import { Icon } from 'astro-icon/components';

// Build calendar URLs from event data
const title = encodeURIComponent(`${event.parentName}'s ${event.eventType}`);
const location = encodeURIComponent(`${event.venue}, ${event.address}`);
const description = encodeURIComponent(`${event.tagline} Organizado por ${event.hostName}.`);

// Parse times for calendar format (YYYYMMDDTHHMMSS)
const dateStr = event.date.replace(/-/g, '');
// Convert "2:00 PM" → 24h
function to24h(time: string): string {
  const [timePart, period] = time.split(' ');
  let [h, m] = timePart.split(':').map(Number);
  if (period === 'PM' && h !== 12) h += 12;
  if (period === 'AM' && h === 12) h = 0;
  return `${String(h).padStart(2, '0')}${String(m).padStart(2, '0')}00`;
}

const startCal = `${dateStr}T${to24h(event.startTime)}`;
const endCal = `${dateStr}T${to24h(event.endTime)}`;

const googleUrl = `https://calendar.google.com/calendar/render?action=TEMPLATE&text=${title}&dates=${startCal}/${endCal}&location=${location}&details=${description}`;

// ICS content for Apple/Outlook
const icsContent = `BEGIN:VCALENDAR
VERSION:2.0
BEGIN:VEVENT
DTSTART:${startCal}
DTEND:${endCal}
SUMMARY:${event.parentName}'s ${event.eventType}
LOCATION:${event.venue}, ${event.address}
DESCRIPTION:${event.tagline} Organizado por ${event.hostName}.
END:VEVENT
END:VCALENDAR`;

const icsDataUri = `data:text/calendar;charset=utf-8,${encodeURIComponent(icsContent)}`;
---

<section class="calendar section animate-on-scroll" id="calendar">
  <p class="calendar__label text-label">Reserva la Fecha</p>

  <div class="calendar__links">
    <a
      href={googleUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="pill-button pill-button--secondary calendar__btn"
    >
      <Icon name="google-calendar" width="16" height="16" aria-hidden="true" />
      Google
    </a>

    <a
      href={icsDataUri}
      download={`${event.parentName}-baby-shower.ics`}
      class="pill-button pill-button--secondary calendar__btn"
    >
      <Icon name="apple-calendar" width="16" height="16" aria-hidden="true" />
      Apple
    </a>

    <a
      href={icsDataUri}
      download={`${event.parentName}-baby-shower.ics`}
      class="pill-button pill-button--secondary calendar__btn"
    >
      <Icon name="outlook-calendar" width="16" height="16" aria-hidden="true" />
      Outlook
    </a>
  </div>
</section>

<style>
  .calendar {
    text-align: center;
    padding-top: var(--space-lg);
    padding-bottom: var(--space-lg);
  }

  .calendar__label {
    color: var(--outline);
    margin-bottom: var(--space-md);
  }

  .calendar__links {
    display: flex;
    justify-content: center;
    gap: var(--space-sm);
    flex-wrap: wrap;
  }

  .calendar__btn {
    font-size: 13px;
    padding: var(--space-sm) var(--space-lg);
    min-height: 40px;
  }
</style>

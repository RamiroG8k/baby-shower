---
import event from "../../data/event.json";

const eventDate = new Date(`${event.date}T14:00:00`).toISOString();
---

<section class="countdown section animate-on-scroll" id="countdown">
  <div class="countdown__timer" id="countdown-timer" data-date={eventDate}>
    <div class="countdown__unit">
      <span class="countdown__number" id="cd-days">--</span>
      <span class="countdown__label text-label">Días</span>
    </div>
    <div class="countdown__dot">:</div>
    <div class="countdown__unit">
      <span class="countdown__number" id="cd-hours">--</span>
      <span class="countdown__label text-label">Horas</span>
    </div>
    <div class="countdown__dot">:</div>
    <div class="countdown__unit">
      <span class="countdown__number" id="cd-min">--</span>
      <span class="countdown__label text-label">Min</span>
    </div>
    <div class="countdown__dot">:</div>
    <div class="countdown__unit">
      <span class="countdown__number" id="cd-sec">--</span>
      <span class="countdown__label text-label">Seg</span>
    </div>
  </div>
  <noscript>
    <p class="countdown__fallback text-body-lg">
      {event.dayOfWeek}, {
        new Date(event.date).toLocaleDateString("es-MX", {
          month: "long",
          day: "numeric",
          year: "numeric",
        })
      }
    </p>
  </noscript>
</section>

<script>
  function startCountdown() {
    const el = document.getElementById("countdown-timer");
    if (!el) return;

    const target = new Date(el.dataset.date!).getTime();
    const days = document.getElementById("cd-days")!;
    const hours = document.getElementById("cd-hours")!;
    const min = document.getElementById("cd-min")!;
    const sec = document.getElementById("cd-sec")!;

    function update() {
      const diff = target - Date.now();

      if (diff <= 0) {
        days.textContent = "0";
        hours.textContent = "0";
        min.textContent = "0";
        sec.textContent = "0";
        return;
      }

      const d = Math.floor(diff / (1000 * 60 * 60 * 24));
      const h = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
      const m = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
      const s = Math.floor((diff % (1000 * 60)) / 1000);

      days.textContent = String(d);
      hours.textContent = String(h).padStart(2, "0");
      min.textContent = String(m).padStart(2, "0");
      sec.textContent = String(s).padStart(2, "0");
    }

    update();
    setInterval(update, 1000);
  }

  startCountdown();
</script>

<style>
  .countdown {
    text-align: center;
    padding-top: 0;
    padding-bottom: var(--space-xl);
  }

  .countdown__timer {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-md);
  }

  .countdown__unit {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-xs);
    background: var(--primary-container);
    border-radius: var(--radius-lg);
    padding: var(--space-md) var(--space-lg);
    min-width: 64px;
  }

  .countdown__number {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 5vw, 2.25rem);
    font-weight: 500;
    color: var(--on-primary-container);
    line-height: 1;
  }

  .countdown__label {
    color: var(--on-primary-container);
    opacity: 0.7;
    font-size: 10px;
  }

  .countdown__dot {
    font-family: var(--font-display);
    font-size: 1.5rem;
    color: var(--outline-variant);
    margin-top: -12px;
  }

  .countdown__fallback {
    color: var(--on-surface-variant);
  }

  @media (max-width: 400px) {
    .countdown__timer {
      gap: var(--space-sm);
    }
    .countdown__unit {
      padding: var(--space-sm) var(--space-md);
      min-width: 56px;
    }
  }
</style>

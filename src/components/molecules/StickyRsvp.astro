---

<div class="sticky-rsvp" id="sticky-rsvp" aria-hidden="true">
  <a href="#rsvp" class="pill-button pill-button--primary sticky-rsvp__btn">
    Confirmar Asistencia
  </a>
</div>

<script>
  const sticky = document.getElementById('sticky-rsvp')!;
  const hero = document.getElementById('hero');
  const rsvp = document.getElementById('rsvp');

  let heroVisible = true;
  let rsvpVisible = false;

  function updateVisibility() {
    const show = !heroVisible && !rsvpVisible;
    sticky.classList.toggle('sticky-rsvp--visible', show);
    sticky.setAttribute('aria-hidden', String(!show));
  }

  if (hero) {
    new IntersectionObserver(([e]) => {
      heroVisible = e.isIntersecting;
      updateVisibility();
    }, { threshold: 0.3 }).observe(hero);
  }

  if (rsvp) {
    new IntersectionObserver(([e]) => {
      rsvpVisible = e.isIntersecting;
      updateVisibility();
    }, { threshold: 0.2 }).observe(rsvp);
  }
</script>

<style>
  .sticky-rsvp {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 100;
    display: flex;
    justify-content: center;
    padding: var(--space-md);
    padding-bottom: max(var(--space-md), env(safe-area-inset-bottom));
    background: linear-gradient(transparent, rgba(250, 250, 243, 0.9) 30%);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    transform: translateY(100%);
    opacity: 0;
    transition: transform 0.4s ease, opacity 0.4s ease;
    pointer-events: none;
  }

  .sticky-rsvp--visible {
    transform: translateY(0);
    opacity: 1;
    pointer-events: auto;
  }

  .sticky-rsvp__btn {
    width: 100%;
    max-width: 320px;
    text-align: center;
    box-shadow: var(--shadow-elevated);
  }
</style>

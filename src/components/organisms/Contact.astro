---
import { Event } from "@models/Event";
import Text from "@atoms/Text.astro";
import Headline from "@atoms/Headline.astro";

const event = Event.getInstance();
---

<section class="contact section animate-on-scroll" id="contact">
    <Headline
        as="p"
        variant="md"
        weight="light"
        italic
        class="contact__message"
    >
        {event.data.closingMessage}
    </Headline>

    <Text as="p" variant="body-md" class="contact__host">
        Con cariño, <strong>{event.data.hostName}</strong>
    </Text>
</section>

<style>
    .contact {
        text-align: center;
        padding-bottom: var(--space-4xl);
    }

    .contact__botanical {
        margin-bottom: var(--space-xl);
    }

    .contact__message {
        font-size: clamp(1.25rem, 4vw, 1.5rem);
        font-weight: 300;
        font-style: italic;
        color: var(--on-surface);
        margin-bottom: var(--space-sm);
        line-height: 1.4;
    }

    .contact__host {
        color: var(--on-surface-variant);
        margin-bottom: var(--space-xl);
    }

    .contact__channels {
        display: flex;
        flex-direction: column;
        gap: var(--space-md);
        align-items: center;
    }

    .contact__btn {
        width: 100%;
        max-width: 280px;
    }
</style>

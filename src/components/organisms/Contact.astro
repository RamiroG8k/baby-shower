---
import event from '../../data/event.json';
import Botanical from '../atoms/Botanical.astro';
import { Icon } from 'astro-icon/components';

const waLink = `https://wa.me/${event.whatsapp.replace(/[^0-9]/g, '')}?text=${encodeURIComponent(`¡Hola! Sobre el Baby Shower de ${event.parentName}...`)}`;
---

<section class="contact section animate-on-scroll" id="contact">
  <div class="contact__botanical">
    <Botanical flip />
  </div>

  <p class="contact__message font-display">
    {event.closingMessage}
  </p>

  <p class="contact__host text-body-md">
    Con cariño, <strong>{event.hostName}</strong>
  </p>

  <div class="contact__channels">
    <a
      href={waLink}
      target="_blank"
      rel="noopener noreferrer"
      class="pill-button pill-button--primary contact__btn"
    >
      <Icon name="whatsapp" width="18" height="18" aria-hidden="true" />
      Contáctanos por WhatsApp
    </a>

    <a
      href={`tel:${event.whatsapp.replace(/[^0-9+]/g, '')}`}
      class="pill-button pill-button--outline contact__btn"
    >
      <Icon name="phone" width="16" height="16" aria-hidden="true" />
      {event.phone}
    </a>
  </div>
</section>

<style>
  .contact {
    text-align: center;
    padding-bottom: var(--space-4xl);
  }

  .contact__botanical {
    margin-bottom: var(--space-xl);
  }

  .contact__message {
    font-size: clamp(1.25rem, 4vw, 1.5rem);
    font-weight: 300;
    font-style: italic;
    color: var(--on-surface);
    margin-bottom: var(--space-sm);
    line-height: 1.4;
  }

  .contact__host {
    color: var(--on-surface-variant);
    margin-bottom: var(--space-xl);
  }

  .contact__channels {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    align-items: center;
  }

  .contact__btn {
    width: 100%;
    max-width: 280px;
  }
</style>

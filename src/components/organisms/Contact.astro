---
import { Event } from '@models/Event';
import { Icon } from 'astro-icon/components';
import Link from '@atoms/Link.astro';

const event = Event.getInstance();
---

<section class="contact section animate-on-scroll" id="contact">
  <div class="contact__botanical">
    <Icon name="botanical" class="botanical botanical--flip" />
  </div>

  <p class="contact__message font-display">
    {event.data.closingMessage}
  </p>

  <p class="contact__host text-body-md">
    Con cariño, <strong>{event.data.hostName}</strong>
  </p>

  <div class="contact__channels">
    <Link
      href={event.whatsAppUrl}
      target="_blank"
      variant="primary"
      class="contact__btn"
    >
      <Icon name="whatsapp" width="18" height="18" aria-hidden="true" />
      Contáctanos por WhatsApp
    </Link>

    <Link
      href={event.phoneUrl}
      variant="outline"
      class="contact__btn"
    >
      <Icon name="phone" width="16" height="16" aria-hidden="true" />
      {event.data.phone}
    </Link>
  </div>
</section>

<style>
  .contact {
    text-align: center;
    padding-bottom: var(--space-4xl);
  }

  .contact__botanical {
    margin-bottom: var(--space-xl);
  }

  .contact__message {
    font-size: clamp(1.25rem, 4vw, 1.5rem);
    font-weight: 300;
    font-style: italic;
    color: var(--on-surface);
    margin-bottom: var(--space-sm);
    line-height: 1.4;
  }

  .contact__host {
    color: var(--on-surface-variant);
    margin-bottom: var(--space-xl);
  }

  .contact__channels {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    align-items: center;
  }

  .contact__btn {
    width: 100%;
    max-width: 280px;
  }
</style>

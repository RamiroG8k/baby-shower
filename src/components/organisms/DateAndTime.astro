---
import event from "@data/event.json";
import Text from "@atoms/Text.astro";

const dateObj = new Date(event.date);
const monthName = dateObj.toLocaleDateString("es-MX", { month: "long" });
const dayNumber = dateObj.getUTCDate();
const year = dateObj.getUTCFullYear();
---

<div class="details__grid animate-on-scroll delay-1">
    <div class="details__block">
        <Text as="span" variant="label">{event.dayOfWeek}</Text>
        <span class="details__day">{dayNumber}</span>
        <span class="details__sub">{monthName} {year}</span>
    </div>

    <div class="details__vdivider" aria-hidden="true"></div>

    <div class="details__block">
        <Text as="span" variant="label">Hora</Text>
        <span class="details__time">{event.startTime}</span>
        {event.endTime && <span class="details__sub">a {event.endTime}</span>}
    </div>
</div>

<style>
    .details {
        text-align: center;
        padding-top: var(--space-lg);
    }

    .details__grid {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: var(--space-xl);
        margin-bottom: var(--space-2xl);
    }

    .details__block {
        display: grid;
        place-items: center;
        gap: var(--space-sm);
    }

    .details__day,
    .details__time {
        font-family: var(--font-display);
        font-size: var(--text-body-2xl);
        font-weight: 400;
        line-height: 1;
        color: var(--on-surface);
    }

    .details__day {
        font-size: var(--text-body-3xl);
    }

    .details__sub {
        font-size: 13px;
        color: var(--on-surface-variant);
    }

    .details__vdivider {
        width: 1.5px;
        height: 60px;
        background: var(--outline-variant);
        border-radius: var(--radius-full);
    }
</style>

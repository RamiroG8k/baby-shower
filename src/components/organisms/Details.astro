---
import event from "@data/event.json";
import Link from "../atoms/Link.astro";
import Headline from "../atoms/Headline.astro";
import InfoCard from "../molecules/InfoCard.astro";
import Separator from "../atoms/Separator.astro";
import { Icon } from "astro-icon/components";
---

<section class="info section animate-on-scroll" id="info">
    <Headline as="h2" variant="md">Detalles</Headline>

    <Separator visible={false} />

    <div class="info__items">
        {
            event.dressCode && (
                <InfoCard icon="dress-code" label="Código de Vestimenta">
                    <span class="info__value">{event.dressCode}</span>
                </InfoCard>
            )
        }

        {
            event.kidsAllowed !== undefined && (
                <InfoCard icon="kids" label="Niños">
                    <span class="info__value">
                        {event.kidsAllowed
                            ? "¡Los pequeños son bienvenidos!"
                            : "Solo adultos, por favor"}
                    </span>
                </InfoCard>
            )
        }

        {
            event.registry && (
                <InfoCard icon="registry" label="Mesa de Regalos">
                    <Link href="/mesa-de-regalos" class="info__link">
                        Sugerencias y Detalles (Opcionales)
                        <Icon
                            name="external-link"
                            width="12"
                            height="12"
                            aria-hidden="true"
                        />
                    </Link>
                </InfoCard>
            )
        }
    </div>
</section>

<style>
    .info {
        text-align: center;
    }

    .info__items {
        display: flex;
        flex-direction: column;
        gap: var(--space-md);
    }

    .info__value {
        font-size: 15px;
        color: var(--on-surface);
    }

    .info__link {
        font-size: 15px;
        display: inline-flex;
        align-items: center;
        gap: 4px;
    }
</style>

---
import event from "@data/event.json";
import { Icon } from "astro-icon/components";
import Link from "@atoms/Link.astro";
import Headline from "@atoms/Headline.astro";
import Card from "../atoms/Card.astro";
import Separator from "../atoms/Separator.astro";

const encodedAddress = encodeURIComponent(event.address);
const mapUrl = `https://www.google.com/maps/dir/?api=1&destination=${encodedAddress}`;
---

<section class="details section" id="details">
    <Card variant="secondary">
        <div class="details__location animate-on-scroll delay-2">
            <div class="details__location-icon">
                <Icon
                    name="map-marker"
                    width="18"
                    height="22"
                    aria-hidden="true"
                />
            </div>
            <Headline as="p" variant="md" class="details__venue"
                >{event.venue}</Headline
            >
            <p class="details__address">{event.address}</p>
        </div>
    </Card>

    <Separator visible={false} />

    <Card variant="primary">
        <div style="border-radius: 1rem; overflow: hidden;">
            <iframe
                width="100%"
                height={300}
                frameborder="0"
                scrolling="no"
                marginheight="0"
                marginwidth="0"
                src="https://maps.google.com/maps?width=100%25&height=500&hl=en&q=Priv.%20Pino%20Suarez%2056,%20Zapopan,%2045100%20Zapopan,%20Jal.+(Baby%20Shower)&t=&z=15&ie=UTF8&iwloc=B&output=embed"
            ></iframe>
        </div>
    </Card>

    <Separator visible={false} />

    <Link
        href={mapUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="details__map-link"
    >
        <Icon name="map" width="14" height="14" aria-hidden="true" />
        Abrir en Maps
    </Link>
</section>

<style>
    .details {
        text-align: center;
        padding-top: var(--space-lg);
    }

    .details__location {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: var(--space-sm);
    }

    .details__location-icon {
        margin-bottom: var(--space-xs);
    }

    .details__venue {
        color: var(--on-surface);
    }

    .details__address {
        font-size: 14px;
        color: var(--on-surface-variant);
        margin-bottom: var(--space-sm);
    }

    .details__map-link {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: var(--space-sm);
        font-size: 13px;
        padding: var(--space-sm) var(--space-lg);
        min-height: 40px;
        margin-top: var(--space-xs);
        background: var(--surface-container-low);
        color: var(--on-surface);
        border-radius: var(--radius-full);
        text-decoration: none;
        transition: all 0.2s ease;
    }

    .details__map-link:hover {
        background: var(--surface-container);
    }
</style>

---
import type { GetStaticPaths } from "astro";
import event from "@data/event.json";
import { Icon } from "astro-icon/components";
import Text from "@components/atoms/Text.astro";
import Headline from "@components/atoms/Headline.astro";
import Separator from "../atoms/Separator.astro";
---

<section class="hero" id="hero">
    <div class="hero__content">
        <div class="hero__heart" style="animation: fadeIn 1s ease 0.2s both;">
            <Icon name="heart" class="hero__heart-icon" aria-hidden="true" />
        </div>

        <Text variant="label" style="animation: fadeUp 0.8s ease 0.3s both;">
            {"Acompáñanos a celebrar el".toUpperCase()}
        </Text>

        <Text
            bold
            variant="label"
            style="letter-spacing: 0.2em; animation: fadeUp 0.8s ease 0.5s both;"
        >
            {event.eventType.toUpperCase()}
        </Text>

        <Headline
            as="h1"
            variant="lg"
            style="animation: fadeUp 0.8s ease 0.7s both;"
        >
            {event.parentName}
        </Headline>

        <Separator visible={false} />

        <img
            src="/bunny-img.png"
            alt="Bunny"
            class="bunny-img"
            style="animation: fadeIn 0.8s ease 0.8s both;"
        />

        <Text
            as="p"
            variant="label"
            italic
            weight="light"
            style="animation: fadeUp 0.8s ease 0.9s both;"
        >
            {event.tagline}
        </Text>
    </div>
</section>

<style>
    .hero {
        position: relative;
        min-height: 100svh;
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
        padding: var(--space-3xl) var(--space-md);
        overflow: hidden;
    }

    .hero__content {
        position: relative;
        z-index: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: var(--space-xs);
    }

    .hero__heart {
        margin-bottom: var(--space-sm);
    }

    .hero__heart-icon {
        width: 20px;
        height: 18px;
        color: var(--tertiary-container);
        opacity: 0.7;
    }

    .bunny-img {
        width: 100%;
        max-width: 200px;
    }
</style>

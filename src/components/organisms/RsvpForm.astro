---
import event from "@data/event.json";

import { Icon } from "astro-icon/components";
import Button from "@/components/atoms/Button.astro";
import Card from "@/components/atoms/Card.astro";
import Separator from "@/components/atoms/Separator.astro";
import Link from "@/components/atoms/Link.astro";
import Headline from "@/components/atoms/Headline.astro";
import Text from "@/components/atoms/Text.astro";
import CalendarLinks from "@/components/molecules/CalendarLinks.astro";

const deadlineDate = new Date(event.rsvpDeadline).toLocaleDateString("es-MX", {
    month: "long",
    day: "numeric",
    year: "numeric",
});

const whatsappPhone = event.whatsapp.replace(/\D/g, "");
const declineText = encodeURIComponent(
    "Hola, no podré asistir al baby shower. ¡Gracias por la invitación!",
);
const adviseText = encodeURIComponent(
    "¡Hola! Tengo un mensaje para los papás...",
);
const whatsappDeclineUrl = `https://wa.me/${whatsappPhone}?text=${declineText}`;
const whatsappAdviseUrl = `https://wa.me/${whatsappPhone}?text=${adviseText}`;
---

<section class="rsvp section animate-on-scroll" id="rsvp">
    <Headline as="h2" variant="md">¿Nos acompañarás?</Headline>

    <Separator visible={false} />

    <Card variant="primary" id="rsvp-card">
        <Separator visible={false} />

        <div class="rsvp__step rsvp__step--choice" id="rsvp-step-choice">
            <div class="rsvp__buttons">
                <Button variant="primary" class="rsvp__choice" id="btn-accept">
                    Asistiré con gusto
                </Button>

                <Link
                    href={whatsappDeclineUrl}
                    variant="outline"
                    id="whatsapp-decline"
                >
                    No podré asistir
                </Link>
            </div>
        </div>

        <div
            class="rsvp__step rsvp__accepted"
            id="rsvp-accepted"
            style="display:none;"
        >
            <div class="rsvp__check">
                <Icon name="check-success" width="48" height="48" />
            </div>
            <Headline as="p" variant="md" class="rsvp__confirm-text">
                ¡Nos encantaría que nos acompañes!
            </Headline>
            <Text as="p" variant="body-md" class="rsvp__confirm-sub">
                Confirma tu asistencia por WhatsApp y guarda la fecha en tu
                calendario
            </Text>

            <CalendarLinks />

            <a
                href={whatsappAdviseUrl}
                target="_blank"
                class="rsvp__whatsapp-link"
                id="whatsapp-confirm"
            >
                <Icon name="whatsapp" width="20" height="20" />
                Confirmar por WhatsApp
            </a>

            <button type="button" class="rsvp__edit-btn" id="rsvp-edit">
                Editar respuesta
            </button>
        </div>

        <Separator visible={false} />
    </Card>

    <Separator visible={false} />

    <Text
        as="p"
        variant="body-md"
        class="rsvp__deadline animate-on-scroll delay-1"
    >
        Por favor confirma tu asistencia antes del <strong
            >{deadlineDate}</strong
        >
    </Text>
</section>

<script>
    const stepChoice = document.getElementById("rsvp-step-choice")!;
    const accepted = document.getElementById("rsvp-accepted")!;
    const btnAccept = document.getElementById("btn-accept")!;

    btnAccept.addEventListener("click", () => {
        stepChoice.style.display = "none";
        accepted.style.display = "flex";
    });

    document.getElementById("rsvp-edit")!.addEventListener("click", () => {
        accepted.style.display = "none";
        stepChoice.style.display = "block";
    });

    const params = new URLSearchParams(window.location.search);
    const phoneOverride = params.get("w");

    if (phoneOverride && /^\d{10,15}$/.test(phoneOverride)) {
        const declineText = encodeURIComponent(
            "Hola, no podré asistir al baby shower. ¡Gracias por la invitación!",
        );
        const adviseText = encodeURIComponent(
            "¡Hola! Tengo un mensaje para los papás...",
        );

        const declineLink = document.getElementById("whatsapp-decline");
        const confirmLink = document.getElementById("whatsapp-confirm");

        if (declineLink)
            declineLink.setAttribute(
                "href",
                `https://wa.me/${phoneOverride}?text=${declineText}`,
            );
        if (confirmLink)
            confirmLink.setAttribute(
                "href",
                `https://wa.me/${phoneOverride}?text=${adviseText}`,
            );
    }
</script>

<style>
    .rsvp {
        text-align: center;
    }

    .rsvp__title {
        margin-bottom: var(--space-lg);
        color: var(--on-surface);
    }

    .rsvp__card {
        padding: var(--space-xl) var(--space-lg);
    }

    .rsvp__buttons {
        display: flex;
        flex-direction: column;
        gap: var(--space-md);
    }

    .rsvp__accepted {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: var(--space-md);
        animation: scaleIn 0.5s ease both;
        padding: var(--space-lg) 0;
    }

    .rsvp__confirm-sub {
        color: var(--on-surface-variant);
    }

    .rsvp__edit-btn {
        font-size: 13px;
        color: var(--outline);
        text-decoration: underline;
        text-underline-offset: 3px;
        padding: var(--space-xs);
        margin-top: var(--space-sm);
    }

    .rsvp__edit-btn:hover {
        color: var(--on-surface-variant);
    }

    .rsvp__whatsapp-link {
        display: inline-flex;
        align-items: center;
        gap: var(--space-sm);
        padding: var(--space-sm) var(--space-md);
        background: #25d366;
        color: white;
        border-radius: var(--radius-default);
        font-size: 14px;
        font-weight: 500;
        text-decoration: none;
        transition: all 0.2s ease;
        margin-top: var(--space-md);
    }

    .rsvp__whatsapp-link:hover {
        background: #128c7e;
        transform: translateY(-1px);
    }

    .rsvp__deadline {
        margin-top: var(--space-lg);
        color: var(--on-surface-variant);
    }
</style>

---
import Layout from "@/layouts/Layout.astro";
import { Icon } from "astro-icon/components";
import Headline from "@/components/atoms/Headline.astro";
import Text from "@/components/atoms/Text.astro";
import Link from "@/components/atoms/Link.astro";
import Separator from "@/components/atoms/Separator.astro";

import registry from "@data/registry.json";
---

<Layout title="Mesa de Regalos — Baby Shower">
    <div class="registry-layout">
        <aside class="registry-sidebar">
            <div class="sidebar-content">
                <div class="sidebar-top">
                    <Headline as="h1" variant="xl">
                        <span transition:name="registry-title">
                            Mesa de Regalos
                        </span>
                    </Headline>

                    <Separator visible={false} />

                    <Text as="p" variant="body-lg" class="sidebar-intro">
                        {registry.intro}
                    </Text>
                </div>

                <Link href="/" variant="outline" class="sidebar-back">
                    Volver a la invitación
                </Link>
            </div>
        </aside>

        <main class="registry-main">
            {
                registry.shops.map((shop, i) => (
                    <section
                        class={`shop-section animate-on-scroll delay-${i + 1}`}
                    >
                        <div class="shop-header">
                            <div class="shop-image-wrapper">
                                <img
                                    src={shop.image}
                                    alt={shop.name}
                                    class="shop-image"
                                    loading="lazy"
                                />
                            </div>

                            <div class="shop-info">
                                <Headline as="h2" variant="md">
                                    {shop.name}
                                </Headline>

                                <Text
                                    as="p"
                                    variant="body-md"
                                    class="shop-description"
                                >
                                    {shop.description}
                                </Text>

                                <Link
                                    href={shop.url}
                                    variant="primary"
                                    target="_blank"
                                    class="shop-cta"
                                >
                                    Ver productos
                                    <Icon
                                        name="external-link"
                                        width="16"
                                        height="16"
                                    />
                                </Link>
                            </div>
                        </div>

                        <div class="suggestions-scroll">
                            {shop.suggestions.map((item) => (
                                <div class="suggestion-card">
                                    <div class="suggestion-squircle">
                                        <div class="suggestion-inner">
                                            <img
                                                src={item.image}
                                                alt={item.label}
                                                class="suggestion-product"
                                                loading="lazy"
                                            />
                                        </div>
                                    </div>
                                    <Text
                                        as="span"
                                        variant="body-md"
                                        class="suggestion-label"
                                    >
                                        {item.label}
                                    </Text>
                                </div>
                            ))}
                        </div>
                    </section>
                ))
            }
        </main>
    </div>
</Layout>

<style>
    .registry-layout {
        display: grid;
        grid-template-columns: 1fr;
        min-height: 100dvh;
        max-width: 100vw;
        overflow-x: hidden;
    }

    @media (min-width: 768px) {
        .registry-layout {
            grid-template-columns: 380px 1fr;
        }
    }

    /* --- Sidebar --- */
    .registry-sidebar {
        position: relative;
        padding: var(--space-xl) var(--space-lg);

        background-color: #f4f1ea;
        background-image:
            linear-gradient(
                90deg,
                rgba(214, 208, 196, 0.5) 50%,
                transparent 50%
            ),
            linear-gradient(rgba(214, 208, 196, 0.5) 50%, transparent 50%);
        background-size: 60px 60px;
    }

    @media (min-width: 768px) {
        .registry-sidebar {
            position: sticky;
            top: 0;
            height: 100dvh;
            overflow-y: auto;
        }
    }

    .sidebar-content {
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        height: 100%;
        min-height: 300px;
    }

    .sidebar-top {
        display: flex;
        flex-direction: column;
    }

    .sidebar-intro {
        color: var(--on-surface-variant);
    }

    .sidebar-back {
        margin-top: var(--space-xl);
        align-self: flex-start;
    }

    /* --- Main Content --- */
    .registry-main {
        padding: var(--space-xl) var(--space-md);
        display: flex;
        flex-direction: column;
        gap: var(--space-3xl);
        min-width: 0;
    }

    @media (min-width: 768px) {
        .registry-main {
            padding: var(--space-xl) var(--space-2xl);
            height: 100dvh;
            overflow-y: auto;
        }
    }

    /* --- Shop Section --- */
    .shop-section {
        display: flex;
        flex-direction: column;
        gap: var(--space-lg);
        min-width: 0;
        max-width: 100%;
    }

    .shop-header {
        display: flex;
        flex-direction: column;
        gap: var(--space-md);
    }

    @media (min-width: 540px) {
        .shop-header {
            flex-direction: row;
            align-items: flex-start;
            gap: var(--space-lg);
        }
    }

    .shop-image-wrapper {
        flex-shrink: 0;
        width: 100%;
        aspect-ratio: 16 / 9;
        border-radius: var(--radius-md);
        overflow: hidden;
        background: var(--surface-container-low);
    }

    @media (min-width: 540px) {
        .shop-image-wrapper {
            max-width: 280px;
            aspect-ratio: 4 / 3;
        }
    }

    .shop-image {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .shop-info {
        display: flex;
        flex-direction: column;
        gap: var(--space-sm);
    }

    .shop-description {
        color: var(--on-surface-variant);
    }

    .shop-cta {
        margin-top: var(--space-sm);
        align-self: flex-start;
    }

    /* --- Suggestions horizontal scroll --- */
    .suggestions-scroll {
        display: flex;
        gap: var(--space-md);
        overflow-x: auto;
        padding-bottom: var(--space-sm);
        scroll-snap-type: x mandatory;
        -webkit-overflow-scrolling: touch;
        max-width: 100%;
    }

    .suggestions-scroll::-webkit-scrollbar {
        height: 4px;
    }

    .suggestions-scroll::-webkit-scrollbar-track {
        background: var(--surface-container-low);
        border-radius: var(--radius-full);
    }

    .suggestions-scroll::-webkit-scrollbar-thumb {
        background: var(--outline-variant);
        border-radius: var(--radius-full);
    }

    .suggestion-card {
        flex-shrink: 0;
        width: 110px;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: var(--space-sm);
        scroll-snap-align: start;
        text-align: center;
    }

    .suggestion-squircle {
        width: 100%;
        aspect-ratio: 1;
        padding: 6px;
        background: var(--primary-fixed);
        border-radius: var(--radius-lg);
    }

    .suggestion-inner {
        width: 100%;
        height: 100%;
        background: var(--surface-container-lowest);
        border-radius: var(--radius-md);
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
    }

    .suggestion-product {
        width: 70%;
        height: 70%;
        object-fit: contain;
    }

    .suggestion-label {
        font-size: 13px;
        color: var(--on-surface-variant);
        line-height: 1.3;
    }
</style>
